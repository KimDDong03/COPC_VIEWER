{
  "name": "copc-viewer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite examples/basic-viewer --config vite.config.ts --host localhost --port 3000",
    "build": "tsc && vite build examples/basic-viewer --config vite.config.ts --outDir ../../dist --emptyOutDir",
    "preview": "vite preview examples/basic-viewer --config vite.config.ts --host localhost --port 3000 --outDir ../../dist",
    "test": "vitest run"
  },
  "dependencies": {
    "cesium": "^1.135.0",
    "copc": "^0.0.8",
    "laz-perf": "^0.0.7",
    "proj4": "^2.20.9"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vite-plugin-cesium": "^1.2.23",
    "vitest": "^4.1.9"
  }
}
