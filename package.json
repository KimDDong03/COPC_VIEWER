{
  "name": "copc-cesium",
  "version": "0.1.0",
  "description": "CesiumJS-native COPC point cloud streaming and visualization library.",
  "license": "MIT",
  "packageManager": "npm@11.16.0",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=22 <23",
      "onFail": "error"
    },
    "packageManager": {
      "name": "npm",
      "version": ">=11.16.0 <12",
      "onFail": "warn"
    }
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "cesium",
    "cesiumjs",
    "copc",
    "point-cloud",
    "lidar",
    "webgis"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KimDDong03/COPC_VIEWER.git"
  },
  "bugs": {
    "url": "https://github.com/KimDDong03/COPC_VIEWER/issues"
  },
  "homepage": "https://github.com/KimDDong03/COPC_VIEWER#readme",
  "type": "module",
  "main": "./dist/lib/index.js",
  "module": "./dist/lib/index.js",
  "types": "./dist/lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/lib/index.js"
    },
    "./core": {
      "types": "./dist/lib/core/index.d.ts",
      "import": "./dist/lib/core/index.js"
    },
    "./cesium": {
      "types": "./dist/lib/cesium/index.d.ts",
      "import": "./dist/lib/cesium/index.js"
    }
  },
  "files": [
    "dist/lib",
    "docs",
    "examples/minimal-layer.ts",
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "SECURITY.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "scripts": {
    "dev": "vite examples/basic-viewer --config vite.config.ts --host localhost --port 3000",
    "build": "npm run build:lib && npm run build:example",
    "build:example": "tsc && vite build examples/basic-viewer --config vite.config.ts --outDir ../../dist/example --emptyOutDir",
    "build:lib": "vite build --config vite.lib.config.ts && tsc -p tsconfig.lib.json && node scripts/normalize-declaration-specifiers.mjs",
    "prepack": "npm run license:evidence:check && npm run build:lib",
    "prepublishOnly": "npm run qc",
    "preview": "vite preview examples/basic-viewer --config vite.config.ts --host localhost --port 3000 --outDir ../../dist/example",
    "benchmark:renderers": "node scripts/benchmark-renderers.mjs",
    "benchmark:smoothness": "node scripts/benchmark-smoothness.mjs",
    "benchmark:smoothness:assert": "node scripts/assert-smoothness-benchmark.mjs",
    "benchmark:smoothness:regression": "node scripts/smoothness-regression-qc.mjs",
    "benchmark:smoothness:regression:assert": "node scripts/assert-smoothness-regression.mjs",
    "benchmark:smoothness:qc": "node scripts/smoothness-qc.mjs",
    "benchmark:smoothness:contest": "node scripts/smoothness-qc.mjs --contest",
    "benchmark:smoothness:cache-reset": "node scripts/smoothness-qc.mjs --cache-reset",
    "benchmark:smoothness:cold-reset": "node scripts/smoothness-qc.mjs --cold-reset",
    "benchmark:smoothness:cold-detail": "node scripts/smoothness-qc.mjs --cold-detail",
    "benchmark:smoothness:zoom-detail": "node scripts/smoothness-qc.mjs --zoom-detail",
    "benchmark:smoothness:warm-zoom-detail": "node scripts/smoothness-qc.mjs --warm-zoom-detail",
    "license:evidence": "node scripts/generate-license-evidence.mjs",
    "license:evidence:check": "node scripts/generate-license-evidence.mjs --check",
    "license:evidence:self-test": "node scripts/generate-license-evidence.mjs --self-test",
    "qc": "node scripts/qc.mjs",
    "qc:contest-device": "node scripts/qc.mjs --omit-warm-zoom-detail && npm run benchmark:smoothness:regression",
    "smoke:example": "node scripts/smoke-example.mjs",
    "smoke:example:file": "node scripts/smoke-example.mjs --local-file",
    "smoke:example:install-browser": "playwright-cli install-browser chrome-for-testing",
    "smoke:package": "node scripts/smoke-package.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@types/emscripten": "^1.41.5",
    "copc": "^0.0.8",
    "laz-perf": "^0.0.7",
    "proj4": "^2.20.9"
  },
  "peerDependencies": {
    "cesium": ">=1.140.0 <2"
  },
  "devDependencies": {
    "@playwright/cli": "0.1.17",
    "cesium": "^1.140.0",
    "typescript": "^7.0.2",
    "vite": "^7.2.7",
    "vite-plugin-cesium": "^1.2.23",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
