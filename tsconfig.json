{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false,
    "baseUrl": ".",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "copc-viewer": ["src/index.ts"],
      "copc-viewer/core": ["src/core/index.ts"],
      "copc-viewer/cesium": ["src/cesium/index.ts"]
    }
  },
  "include": ["src", "examples", "vite.config.ts", "vite.lib.config.ts"]
}
